# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=jboard
POSTGRES_USER=jboard_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://jboard_user:change_me_in_production@postgres:5432/jboard

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Backend ──────────────────────────────────────────────────
PORT=3001
SESSION_SECRET=change_me_to_a_long_random_string_in_production
SESSION_EXPIRY_HOURS=24

# ─── Frontend (NEXT_PUBLIC_ vars are exposed to the browser) ──
NEXT_PUBLIC_API_URL=http://localhost/api
