# Copy this file to .env.production and fill in real values before deploying.
# NEVER commit .env.production to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=jboard
POSTGRES_USER=jboard_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://jboard_user:CHANGE_ME_strong_password_here@postgres:5432/jboard

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3001

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_ME_64_random_bytes_hex

SESSION_EXPIRY_HOURS=24

# ── Frontend ──────────────────────────────────────────────────────────────────
# The public URL users type into their browser
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
